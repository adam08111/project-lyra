# Copy to .env for local dev (.env is gitignored — never commit real keys).
# On Vercel, set these in Settings → Environment Variables instead.

# Required — powers everything: coaching, X-Ray, training, proofread, AND photo
# OCR (Gemini vision). This one key is all the app needs.
GEMINI_API_KEY=AIza-your-key-here

# Deploy-only: the shared-password gate (Vercel middleware.js). Unset = open site.
GATE_PASS=your-review-password
GATE_USER=lyra

# Supabase sync (P0). Public-by-design: the anon key's authority is Row Level Security,
# not secrecy. Documented exception to the keys-behind-the-proxy convention — do NOT
# move it behind /api. service_role must NEVER appear in the repo, the client bundle, or
# Vercel env. Unset both to disable sync entirely (the app is byte-identical without them).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
