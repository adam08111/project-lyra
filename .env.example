# Copy to .env for local dev (.env is gitignored — never commit real keys).
# On Vercel, set these in Settings → Environment Variables instead.

# Required — all text AI (coaching, X-Ray, training, proofread) runs on Gemini.
GEMINI_API_KEY=AIza-your-key-here

# Only needed for photo OCR (the camera/gallery "read this photo" buttons use
# Claude vision). Leave unset to ship without OCR — text paste still works.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Deploy-only: the shared-password gate (Vercel middleware.js). Unset = open site.
GATE_PASS=your-review-password
GATE_USER=lyra
